# Smart NPCs environment variables.
# Copy this file to smallville/.env and fill in real values.
# Tests that don't hit the network will run with stub values like "test".

# --- LLM providers (OpenAI-compatible) ---
# MeshAPI: https://developers.meshapi.ai
MESHAPI_API_KEY=replace-with-your-meshapi-key
MESHAPI_MODEL=gpt-4o-mini
MESHAPI_BASE_URL=https://api.meshapi.ai/v1

# OpenRouter (fallback): https://openrouter.ai
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Demo timing (optional overrides) ---
# Maximum sim time before propagation must have reached the market district.
SMART_NPC_MAX_SIM_T=2.0
# Wall-clock seconds between demo orchestrator ticks.
SMART_NPC_TICK_SECONDS=0.2

# --- Frontend ---
# Where the FastAPI smart_npc_api is served. The Phaser frontend posts here.
SMART_NPC_API=http://localhost:8000